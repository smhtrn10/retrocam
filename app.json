{
  "expo": {
    "name": "RetroCam",
    "slug": "retrocam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "retrocam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.retrocam.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.retrocam.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://retrocam.com/"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "RetroCam accesses your photo library so you can select existing photos and apply retro filters to them.",
          "savePhotosPermission": "RetroCam saves your edited retro-style photos and videos directly to your photo library.",
          "granularPermissions": [
            "photo",
            "video",
            "audio"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "RetroCam uses your camera to capture photos and apply retro-style filters in real time. For example, you can shoot a photo and instantly see it transformed with a vintage film look.",
          "microphonePermission": "RetroCam uses the microphone to record audio while capturing retro-style video clips. For example, when you record a video, the microphone captures sound so your clip includes audio."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RetroCam accesses your photo library so you can select existing photos and apply retro filters to them.",
          "cameraPermission": "RetroCam uses your camera to capture photos and apply retro-style filters in real time."
        }
      ],

      "expo-font",
      "expo-web-browser",
      "expo-localization",
      "expo-video",
      [
        "@config-plugins/ffmpeg-kit-react-native",
        {
          "package": "full-gpl"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://retrocam.com/"
      },
      "eas": {
        "projectId": "76b32914-4a2e-4223-900a-6f52286ad17d"
      }
    }
  }
}
